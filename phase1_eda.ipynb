        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 找出最严重的几天\n",
        "top_days = daily_total.nlargest(5)\n",
        "print(\"=== 停电最严重的 5 天 ===\")\n",
        "for date, val in top_days.items():\n",
        "    print(f\"  {date.strftime('%Y-%m-%d')}: {val:,.0f} 户\")"
      ]
