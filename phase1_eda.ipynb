        "axes[2].set_title(\"每日总停电数\")\n",
        "axes[2].set_xlabel(\"日期\")\n",
        "axes[2].set_ylabel(\"停电户数\")\n",
        "axes[2].tick_params(axis='x', rotation=45)\n",
